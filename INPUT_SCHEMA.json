{
    "title": "Instagram Running Influencer Email Extractor",
    "description": "Scrapes Instagram running/marathon accounts and extracts emails from: Instagram Email button, bio text, Linktree, and personal websites.",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "hashtags": {
            "title": "Hashtags to search",
            "type": "array",
            "description": "Instagram hashtags to scrape (without #).",
            "editor": "stringList",
            "default": [
                "running","marathon","halfmarathon","runningcommunity",
                "runnersofinstagram","ultramarathon","trailrunning",
                "runnerlife","runningmotivation","roadrunning",
                "marathontraining","runningcoach","runningwomen",
                "instarunners","runner","runhappy","marathonrunner",
                "halfmarathontraining","runningdaily","trailrunner",
                "runninglifestyle","morningrun","runningislife",
                "marathoners","runningworld","bostonmarathon",
                "runforlife","runningmen","hyrox","runcoach"
            ]
        },
        "minFollowers": {
            "title": "Minimum follower count",
            "type": "integer",
            "description": "Only save profiles with at least this many followers.",
            "minimum": 1000,
            "default": 5000,
            "prefill": 5000
        },
        "maxResults": {
            "title": "Maximum results",
            "type": "integer",
            "description": "Stop after saving this many qualifying profiles.",
            "minimum": 1,
            "maximum": 100000,
            "default": 500,
            "prefill": 500
        },
        "maxPagesPerHashtag": {
            "title": "Pages per hashtag",
            "type": "integer",
            "description": "How many pages to fetch per hashtag. Each page = ~20 users. Set to 50 for ~1000 users per hashtag.",
            "minimum": 1,
            "maximum": 100,
            "default": 10,
            "prefill": 10
        },
        "sessionId": {
            "title": "Instagram Session ID (sessionid cookie)",
            "type": "string",
            "description": "Your Instagram sessionid cookie. Required for best results.",
            "editor": "textfield",
            "isSecret": true
        },
        "csrfToken": {
            "title": "Instagram CSRF Token (optional)",
            "type": "string",
            "description": "Your Instagram csrftoken cookie value. Optional.",
            "editor": "textfield",
            "isSecret": true
        },
        "proxyConfiguration": {
            "title": "Proxy configuration",
            "type": "object",
            "description": "Residential proxies strongly recommended.",
            "editor": "proxy",
            "default": { "useApifyProxy": true, "apifyProxyGroups": ["RESIDENTIAL"] },
            "prefill": { "useApifyProxy": true, "apifyProxyGroups": ["RESIDENTIAL"] }
        }
    },
    "required": []
}
