{
  "title": "Instagram Username Extractor (Phase 1)",
  "description": "Extracts usernames from Instagram hashtags. Auto-discovers related hashtags. Saves state so it survives server migrations.",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "hashtags": {
      "title": "Seed hashtags",
      "type": "array",
      "description": "Starting hashtags. Actor auto-discovers related ones up to maxHashtags total.",
      "editor": "stringList",
      "default": [
        "running",
        "marathon",
        "halfmarathon",
        "runnersofinstagram",
        "runningcoach"
      ],
      "prefill": [
        "running",
        "marathon",
        "halfmarathon",
        "runnersofinstagram",
        "runningcoach"
      ]
    },
    "maxHashtags": {
      "title": "Max total hashtags",
      "type": "integer",
      "description": "Total hashtags to process (seeds + auto-discovered). Each gives ~20 usernames.",
      "minimum": 5,
      "maximum": 3000,
      "default": 50,
      "prefill": 50
    },
    "maxPagesPerHashtag": {
      "title": "Pages per hashtag",
      "type": "integer",
      "description": "Each page = ~12-24 usernames. Default 50 pages = ~600 usernames per hashtag.",
      "minimum": 1,
      "maximum": 1000,
      "default": 50,
      "prefill": 50
    },
    "sessionId": {
      "title": "Instagram Session ID",
      "type": "string",
      "description": "From Chrome Console: document.cookie.split(';').find(c=>c.trim().startsWith('sessionid')).split('=')[1]",
      "editor": "textfield",
      "isSecret": true
    },
    "csrfToken": {
      "title": "Instagram CSRF Token",
      "type": "string",
      "description": "From Chrome Console: document.cookie.split(';').find(c=>c.trim().startsWith('csrftoken')).split('=')[1]",
      "editor": "textfield",
      "isSecret": true
    },
    "proxyConfiguration": {
      "title": "Proxy configuration",
      "type": "object",
      "editor": "proxy",
      "default": {
        "useApifyProxy": true,
        "apifyProxyGroups": [
          "RESIDENTIAL"
        ]
      },
      "prefill": {
        "useApifyProxy": true,
        "apifyProxyGroups": [
          "RESIDENTIAL"
        ]
      }
    }
  },
  "required": []
}
